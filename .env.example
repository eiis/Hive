# Hive Configuration
# Copy this file to .env and fill in your API keys

# Claude API Key (required for Claude adapter)
ANTHROPIC_API_KEY=sk-ant-xxx

# OpenAI API Key (required for OpenAI/GPT adapter)
OPENAI_API_KEY=sk-xxx

# OpenAI Compatible API (for Ollama, DeepSeek, Qwen, etc.)
# OPENAI_COMPATIBLE_BASE_URL=http://localhost:11434/v1
# OPENAI_COMPATIBLE_API_KEY=ollama
# OPENAI_COMPATIBLE_MODEL=qwen2.5:7b

# Google Gemini API Key
# GEMINI_API_KEY=xxx

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=sqlite+aiosqlite:///./hive.db

# Default model for Foreman
FOREMAN_MODEL=claude
